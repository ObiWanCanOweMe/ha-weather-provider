#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

CONFIG_DIR="${PWD}/config"
mkdir -p "${CONFIG_DIR}"

if [[ ! -f "${CONFIG_DIR}/configuration.yaml" ]]; then
  hass --config "${CONFIG_DIR}" --script ensure_config
fi

export PYTHONPATH="${PWD}/custom_components${PYTHONPATH:+:${PYTHONPATH}}"
hass --config "${CONFIG_DIR}" --debug
